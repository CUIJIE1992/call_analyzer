{
  "version": 2,
  "buildCommand": null,
  "installCommand": "pip install --upgrade pip && pip install Flask==3.0.0 Flask-CORS==4.0.0 Werkzeug==3.0.1 python-dotenv==1.0.0 requests==2.31.0",
  "framework": null,
  "outputDirectory": null,
  "rewrites": [
    {
      "source": "/static/(.*)",
      "destination": "/static/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  }
}
